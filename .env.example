# Copy this file to `.env` and fill in real values for local development.
# In production / on Replit, set these as Secrets in the Secrets tab — DO NOT commit `.env`.

# --- Database (Neon Postgres — preferred) ---
# Get your connection string from https://console.neon.tech → your project → Connection Details
# Must include ?sslmode=require at the end.
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# --- Database fallback (Replit built-in Postgres) ---
# Replit sets this automatically when a database is provisioned.
# NEON_DATABASE_URL takes priority if both are set.
DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Replit Auth (OIDC) ---
# Random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-hex-string

# Optional — only needed when running OUTSIDE Replit. On Replit these are
# injected automatically.
# REPL_ID=your-repl-id
# REPLIT_DOMAINS=your-app.replit.app
# ISSUER_URL=https://replit.com/oidc

# --- Email (Gmail SMTP for the `message` command) ---
# 16-character Google App Password (NOT your normal Gmail password).
# Generate at: https://myaccount.google.com/apppasswords
# 2-Step Verification must be enabled on the Google account first.
# If left blank, messages are still stored in the database; only the
# email send is skipped.
GMAIL_APP_PASSWORD=
